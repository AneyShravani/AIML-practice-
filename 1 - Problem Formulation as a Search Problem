# Two-Room Vacuum Cleaner Agent

# Initial room status
roomA = input("Enter status of Room A (clean/dirty): ").lower()
roomB = input("Enter status of Room B (clean/dirty): ").lower()

location = "A"   # Agent starts in Room A

while True:
    print("\nAgent Location:", location)

    if location == "A":
        if roomA == "dirty":
            print("Room A is dirty -> Cleaning...")
            roomA = "clean"
        else:
            print("Room A is clean -> Moving to Room B")
            location = "B"

    elif location == "B":
        if roomB == "dirty":
            print("Room B is dirty -> Cleaning...")
            roomB = "clean"
        else:
            print("Room B is clean -> Moving to Room A")
            location = "A"

    # Stop when both rooms are clean
    if roomA == "clean" and roomB == "clean":
        print("\nBoth rooms are clean. Task completed!")
        break

